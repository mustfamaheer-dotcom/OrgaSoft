rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /siteData/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@orga4soft.com';
    }
    match /userPreferences/{document} {
      allow read, write: if true;
    }
    match /visitorEvents/{eventId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.email == 'admin@orga4soft.com';
      allow update, delete: if false;
    }
    match /visitorStats/{date} {
      allow read: if request.auth != null && request.auth.token.email == 'admin@orga4soft.com';
      allow write: if request.auth != null && request.auth.token.email == 'admin@orga4soft.com';
    }
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
